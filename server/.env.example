# ① 공공데이터포털 (data.go.kr) 서비스 키
#    마이페이지 → 오픈API → 인증키 발급/관리 에서 확인
API_SERVICE_KEY=여기에_서비스키_입력

# ② 사용할 데이터셋 엔드포인트
#    data.go.kr 에서 원하는 데이터셋 클릭 → '미리보기' 탭 → 요청 URL 복사
#    예시: https://api.odcloud.kr/api/15126861/v1/uddi:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
API_ENDPOINT=https://api.odcloud.kr/api/여기에_엔드포인트_입력

PORT=3001
